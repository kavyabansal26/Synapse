rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ===============================================================
    // USER SUB-COLLECTIONS (Scoped to the authenticated user)
    // ===============================================================
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /tasks/{taskId} {
        allow read, write: if isOwner(uid);
      }
      match /habits/{habitId} {
        allow read, write: if isOwner(uid);
      }
      match /timetable/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /calendar/{eventId} {
        allow read, write: if isOwner(uid);
      }
      match /focusSessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ===============================================================
    // GROUP WORKSPACES (Shared via unique join codes)
    // ===============================================================
    match /groups/{code} {
      // Anyone authenticated can read or create a group
      allow read, create: if isAuth();
      // Only the owner can update core group details (like transferring ownership)
      allow update: if isAuth() && resource.data.ownerName != null;
      allow delete: if false; // Disallow deletion for now for safety
      
      match /messages/{messageId} {
        // Any auth user can participate in the chat
        allow read, create: if isAuth();
      }
      
      match /notes/{noteId} {
        // Any auth user can share notes in the group
        allow read, write: if isAuth();
      }
    }
    
  }
}
